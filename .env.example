# 法律 Agent 环境变量示例
# 复制此文件为 .env 并填写实际值

# ═══════════════════════════════════════════
#  MiniMax-M3（官方旗舰模型）
# ═══════════════════════════════════════════
OPENAI_API_KEY=sk-cp-your-minimax-key
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# ═══════════════════════════════════════════
#  备选模型
# ═══════════════════════════════════════════
