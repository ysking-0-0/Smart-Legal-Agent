# 法律 Agent 环境变量示例
# 复制此文件为 .env 并填写实际值

# DeepSeek 配置（推荐，国内直连）
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 或使用 OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 或使用 Ollama 本地模型（无需配置以上变量）
# 安装 Ollama 后运行: ollama pull qwen2:7b
# 然后在 config/config.yaml 中设置 llm.provider: "ollama"
